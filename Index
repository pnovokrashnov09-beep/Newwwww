<!DOCTYPE html>
<html lang="ru" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Napoli Pizza</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    :root{
      --red:#C8102E;
      --red-dark:#9B0B22;
      --cream:#FDF6EC;
      --dark:#1A1007;
      --gold:#D4A017;
      --green:#2D6A4F;
      --gray:#6B6B6B;
      --light:#F5EFE6;
      --white:#fff;
      --line:rgba(0,0,0,0.08);
      --shadow:0 10px 30px rgba(0,0,0,0.08);
      --shadow2:0 14px 40px rgba(0,0,0,0.14);
    }
    *{box-sizing:border-box}
    html,body{margin:0;padding:0}
    body{
      font-family:"DM Sans",sans-serif;
      background:var(--cream);
      color:var(--dark);
      min-height:100vh;
    }
    button,input,textarea{font:inherit}
    .page{display:none}
    .page.active{display:block}

    nav{
      position:sticky;top:0;z-index:100;
      background:var(--dark);
      color:#fff;
      box-shadow:0 2px 20px rgba(0,0,0,0.35);
    }
    .nav-row1,.nav-row2,.nav-row3{
      display:flex;align-items:center;gap:.75rem;
      padding:0 1.5rem;
    }
    .nav-row1{
      height:56px;
    }
    .logo{
      font-family:"Playfair Display",serif;
      font-size:1.45rem;
      letter-spacing:1px;
      white-space:nowrap;
      flex-shrink:0;
    }
    .logo span{color:var(--red)}
    .nav-spacer{flex:1}
    .nav-center{display:flex;gap:.5rem;align-items:center}
    .nav-tab{
      border:none;background:transparent;color:#c8c8c8;
      padding:.45rem .9rem;border-radius:10px;cursor:pointer;
      font-weight:600;transition:.2s;
    }
    .nav-tab.active,.nav-tab:hover{
      background:rgba(255,255,255,.1);color:#fff;
    }
    .cart-wrap{position:relative}
    .cart-btn{
      background:var(--red);color:#fff;border:none;cursor:pointer;
      padding:.45rem .9rem;border-radius:10px;font-weight:700;
      display:flex;align-items:center;gap:.45rem;transition:.2s;
    }
    .cart-btn:hover{background:var(--red-dark)}
    .cart-count{
      background:var(--gold);color:var(--dark);
      width:22px;height:22px;border-radius:50%;
      display:inline-flex;align-items:center;justify-content:center;
      font-size:.75rem;font-weight:800;
    }

    .nav-row2{
      padding:.45rem 1.5rem;
      border-top:1px solid rgba(255,255,255,.08);
      background:rgba(0,0,0,.15);
      justify-content:center;
      flex-wrap:wrap;
    }
    .currency-switcher{
      display:flex;gap:.35rem;align-items:center;flex-wrap:wrap;
    }
    .cur-btn{
      padding:.28rem .65rem;border-radius:8px;cursor:pointer;
      border:1.5px solid rgba(255,255,255,.2);
      background:transparent;color:#cfcfcf;font-size:.78rem;
      font-weight:700;transition:.2s;
    }
    .cur-btn.active{
      border-color:var(--gold);color:var(--gold);
    }
    .cur-btn:hover{border-color:#fff;color:#fff}
    .nav-divider{width:1px;height:18px;background:rgba(255,255,255,.18);margin:0 .2rem}
    .nav-phone{font-weight:800;color:var(--gold);letter-spacing:1px}

    .nav-row3{
      padding:.35rem 1.5rem .55rem;
      border-top:1px solid rgba(255,255,255,.05);
      background:rgba(0,0,0,.22);
      justify-content:center;
    }

    .cart-backdrop{
      display:none;position:fixed;inset:0;z-index:299;background:rgba(0,0,0,.25)
    }
    .cart-backdrop.open{display:block}
    .cart-dropdown{
      position:absolute;top:calc(100% + 10px);right:0;
      width:360px;max-width:calc(100vw - 1rem);
      background:#fff;border-radius:16px;box-shadow:var(--shadow2);
      z-index:300;display:none;flex-direction:column;
      max-height:calc(100vh - 110px);overflow:hidden;border:1px solid var(--line);
    }
    .cart-dropdown.open{display:flex}
    .cart-dropdown::before{
      content:"";position:absolute;top:-7px;right:18px;
      width:14px;height:14px;background:#fff;
      border-left:1px solid var(--line);border-top:1px solid var(--line);
      transform:rotate(45deg);
    }
    .cart-header{
      padding:1rem 1.2rem;border-bottom:1px solid #eee;
      display:flex;justify-content:space-between;align-items:center;
    }
    .cart-header h2{
      margin:0;font-family:"Playfair Display",serif;font-size:1.15rem;color:var(--dark);
    }
    .close-btn{border:none;background:none;cursor:pointer;font-size:1.2rem;color:var(--gray)}
    .cart-items{overflow-y:auto;padding:.6rem 1.2rem;flex:1}
    .empty-cart{text-align:center;padding:2rem 1rem;color:var(--gray)}
    .empty-cart .emoji{font-size:2.5rem;display:block;margin-bottom:.5rem}
    .cart-item{
      display:flex;gap:.75rem;align-items:center;
      padding:.75rem 0;border-bottom:1px solid #f0f0f0;
    }
    .ci-emoji{font-size:1.6rem;width:36px;text-align:center;flex-shrink:0}
    .ci-info{flex:1;min-width:0}
    .ci-name{
      font-size:.9rem;font-weight:700;white-space:nowrap;
      overflow:hidden;text-overflow:ellipsis;
    }
    .ci-price{font-weight:800;color:var(--red);font-size:.9rem;flex-shrink:0}
    .qty-ctrl{display:flex;align-items:center;gap:.4rem;margin-top:.3rem}
    .qty-btn{
      width:24px;height:24px;border-radius:50%;
      border:1.5px solid #ddd;background:#fff;cursor:pointer;
      display:flex;align-items:center;justify-content:center;
    }
    .qty-btn:hover{border-color:var(--red);color:var(--red)}
    .qty-val{min-width:18px;text-align:center;font-weight:800;font-size:.9rem}
    .cart-footer{
      padding:1rem 1.2rem;border-top:1px solid #eee;
      display:none;
    }
    .cart-total{
      display:flex;justify-content:space-between;
      font-weight:800;margin-bottom:.75rem;
    }
    .checkout-btn{
      width:100%;background:var(--red);color:#fff;border:none;cursor:pointer;
      padding:.9rem;border-radius:12px;font-weight:800;transition:.2s;
    }
    .checkout-btn:hover{background:var(--red-dark)}

    .hero{
      position:relative;
      background:
        linear-gradient(135deg, rgba(26,16,7,.72), rgba(26,16,7,.34)),
        url('https://images.unsplash.com/photo-1513104890138-7c749659a591?auto=format&fit=crop&w=1600&q=80') center/cover;
      color:#fff;
      min-height:58vh;
      display:flex;
      align-items:flex-end;
    }
    .hero-inner{
      width:100%;
      padding:3.5rem 1.5rem 2rem;
      max-width:1200px;
      margin:0 auto;
    }
    .hero-badge{
      display:inline-block;background:rgba(212,160,23,.16);
      border:1px solid rgba(212,160,23,.45);
      color:#ffe7a3;padding:.35rem .75rem;border-radius:999px;
      font-weight:700;font-size:.85rem;margin-bottom:1rem;
    }
    .hero h1{
      font-family:"Playfair Display",serif;
      font-size:clamp(2.2rem,5vw,4.6rem);
      line-height:1.02;margin:0 0 1rem;
      max-width:780px;
    }
    .hero p{
      max-width:620px;font-size:1.05rem;line-height:1.7;margin:0 0 1.6rem;color:#f2f2f2;
    }
    .hero-actions{display:flex;gap:.8rem;flex-wrap:wrap}
    .hero-btn{
      border:none;cursor:pointer;border-radius:14px;
      padding:.95rem 1.35rem;font-weight:800;
      text-decoration:none;display:inline-flex;align-items:center;gap:.45rem;
      transition:.2s;
    }
    .hero-btn.primary{background:var(--red);color:#fff}
    .hero-btn.primary:hover{background:var(--red-dark)}
    .hero-btn.secondary{background:#fff;color:var(--dark)}
    .hero-btn.secondary:hover{transform:translateY(-1px)}

    .category-bar{
      display:flex;gap:.55rem;padding:1.4rem 1.5rem .2rem;
      overflow-x:auto;scrollbar-width:none;
    }
    .category-bar::-webkit-scrollbar{display:none}
    .cat-btn{
      white-space:nowrap;padding:.55rem 1.15rem;border:2px solid transparent;
      border-radius:999px;cursor:pointer;font-weight:700;font-size:.92rem;
      background:var(--light);color:var(--gray);transition:.2s;
    }
    .cat-btn.active{
      background:var(--red);color:#fff;border-color:var(--red);
    }
    .cat-btn:hover:not(.active){border-color:var(--red);color:var(--red)}
    .menu-section{padding:1rem 1.5rem 3rem}
    .section-title{
      font-family:"Playfair Display",serif;
      font-size:2rem;margin:0 0 1rem;color:var(--dark);
    }
    .section-sub{margin:0 0 1.25rem;color:var(--gray);line-height:1.6}
    .menu-grid{
      display:grid;
      grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
      gap:1.2rem;
    }
    .card{
      background:#fff;border-radius:18px;overflow:hidden;
      box-shadow:var(--shadow);transition:.25s;
      display:flex;flex-direction:column;
    }
    .card:hover{transform:translateY(-4px);box-shadow:var(--shadow2)}
    .card-img{
      height:170px;display:flex;align-items:center;justify-content:center;
      font-size:4.2rem;background:var(--light);position:relative;
    }
    .card-badge{
      position:absolute;top:10px;right:10px;background:var(--red);
      color:#fff;font-size:.72rem;font-weight:800;padding:.22rem .6rem;border-radius:999px;
      text-transform:uppercase;
    }
    .card-body{padding:1rem;flex:1;display:flex;flex-direction:column}
    .card-name{
      font-family:"Playfair Display",serif;font-size:1.14rem;font-weight:800;margin-bottom:.25rem;
    }
    .card-desc{
      font-size:.84rem;color:var(--gray);margin:.3rem 0 .8rem;line-height:1.5;flex:1;
    }
    .size-sel{display:flex;gap:.4rem;margin-bottom:.85rem}
    .size-opt{
      flex:1;padding:.33rem;border:1.5px solid #ddd;border-radius:10px;
      cursor:pointer;text-align:center;font-size:.8rem;font-weight:700;
      background:#fff;transition:.2s;
    }
    .size-opt.selected{border-color:var(--red);background:#fff5f7;color:var(--red)}
    .card-footer{
      display:flex;align-items:center;justify-content:space-between;
    }
    .card-price{font-size:1.15rem;font-weight:800;color:var(--red)}
    .add-btn{
      background:var(--dark);color:#fff;border:none;cursor:pointer;
      width:38px;height:38px;border-radius:50%;
      font-size:1.3rem;display:flex;align-items:center;justify-content:center;
      transition:.2s;
    }
    .add-btn:hover{background:var(--red);transform:scale(1.08)}

    .checkout-wrap{max-width:660px;margin:2rem auto;padding:0 1.5rem 4rem}
    .form-title{
      font-family:"Playfair Display",serif;font-size:2rem;margin:0 0 1rem;
    }
    .summary-box{
      background:#fff;border-radius:16px;padding:1.2rem;
      margin-bottom:1.2rem;box-shadow:var(--shadow);
    }
    .summary-title{font-weight:800;margin-bottom:.8rem;font-size:.96rem}
    .os-line{
      display:flex;justify-content:space-between;gap:1rem;
      font-size:.92rem;padding:.25rem 0;
    }
    .os-line.total{
      font-weight:800;font-size:1.05rem;border-top:1px solid #eee;margin-top:.5rem;padding-top:.75rem;
    }
    .empty-msg{color:var(--gray);font-size:.92rem;text-align:center;padding:1rem 0}
    .delivery-type{display:flex;gap:.5rem;margin-bottom:1.2rem}
    .del-opt{
      flex:1;padding:.8rem;border:2px solid #ddd;border-radius:12px;
      cursor:pointer;text-align:center;font-weight:700;font-size:.92rem;
      background:#fff;transition:.2s;
    }
    .del-opt.selected{border-color:var(--red);background:#fff5f7;color:var(--red)}
    .form-group{margin-bottom:1rem}
    .form-group label{
      display:block;font-size:.86rem;font-weight:700;margin-bottom:.4rem;
    }
    .form-group input,.form-group textarea{
      width:100%;padding:.8rem 1rem;border:1.5px solid #ddd;border-radius:10px;
      font-family:inherit;font-size:.95rem;transition:.2s;background:#fff;color:var(--dark);
    }
    .form-group input:focus,.form-group textarea:focus{outline:none;border-color:var(--red)}
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .map-section{margin-bottom:1rem}
    .map-label{
      font-size:.86rem;font-weight:700;margin-bottom:.5rem;display:flex;align-items:center;gap:.5rem;
    }
    .map-container{
      width:100%;height:320px;border-radius:14px;overflow:hidden;border:2px solid #ddd;background:#e8e0d8;
    }
    .map-container iframe{width:100%;height:100%;border:none;display:block}
    .map-hint{font-size:.78rem;color:var(--gray);margin-top:.4rem;text-align:center}
    .zones{display:flex;flex-wrap:wrap;gap:.4rem;margin-bottom:.75rem}
    .zone-btn{
      padding:.38rem .9rem;background:#fff;border:1.5px solid #ddd;border-radius:999px;
      font-size:.82rem;cursor:pointer;font-family:inherit;transition:.2s;
    }
    .zone-btn:hover{border-color:var(--red);color:var(--red)}
    .zone-btn.active{background:#fff5f7;border-color:var(--red);color:var(--red);font-weight:700}
    .info-box{
      padding:.75rem 1rem;border-radius:12px;font-size:.86rem;margin-bottom:.75rem;display:none;
    }
    .info-box.show{display:block}
    .info-box.green{
      background:#d1fae5;color:#065f46;border:1px solid #6ee7b7;
    }
    .divider{
      text-align:center;margin:1rem 0 .8rem;color:#aaa;font-size:.8rem;position:relative;
    }
    .divider::before,.divider::after{
      content:"";position:absolute;top:50%;width:44px;height:1px;background:#ddd;
    }
    .divider::before{left:0}.divider::after{right:0}
    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}
    .field{margin-bottom:0}
    .field label{
      display:block;font-size:.8rem;font-weight:700;margin-bottom:.3rem;color:#444;
    }
    .field input{
      width:100%;padding:.68rem .85rem;border:1.5px solid #ddd;border-radius:9px;
      font-size:.92rem;font-family:inherit;background:#fff;
    }
    .field input:focus{outline:none;border-color:var(--red)}
    .submit-btn{
      width:100%;background:var(--red);color:#fff;border:none;cursor:pointer;
      padding:1.05rem;border-radius:14px;font-size:1.02rem;font-weight:800;
      transition:.2s;margin-top:.5rem;
    }
    .submit-btn:hover{background:var(--red-dark);transform:translateY(-1px)}

    .success-wrap{text-align:center;padding:3rem 1rem}
    .success-wrap.show{display:block}
    .success-emoji{font-size:4rem;display:block;margin-bottom:1rem}
    .success-wrap h2{
      font-family:"Playfair Display",serif;font-size:2rem;margin:0 0 .5rem;
    }
    .success-wrap p{color:var(--gray);margin-bottom:1.5rem;line-height:1.6}
    .order-number{
      background:var(--dark);color:#fff;padding:.9rem 2rem;border-radius:12px;
      font-size:1.1rem;font-weight:800;display:inline-block;margin-bottom:1.5rem;
    }
    .success-sms{
      background:var(--light);border-radius:12px;padding:.9rem 1.1rem;
      font-size:.9rem;margin-bottom:1.5rem;
    }
    .menu-btn{
      background:var(--red);color:#fff;border:none;cursor:pointer;
      padding:.9rem 2rem;border-radius:12px;font-size:.96rem;font-weight:800;
      text-decoration:none;display:inline-block;
    }
    .toast{
      position:fixed;bottom:2rem;right:2rem;background:var(--dark);color:#fff;
      padding:.95rem 1.4rem;border-radius:12px;font-size:.92rem;font-weight:600;
      z-index:999;transform:translateY(120px);opacity:0;transition:.3s;pointer-events:none;
    }
    .toast.show{transform:translateY(0);opacity:1}

    @media (max-width: 900px){
      .hero{min-height:52vh}
      .nav-center{display:none}
      .menu-grid{grid-template-columns:repeat(auto-fill,minmax(240px,1fr))}
    }
    @media (max-width: 640px){
      .nav-row1,.nav-row2,.nav-row3{padding-left:.75rem;padding-right:.75rem}
      .nav-row1{height:48px}
      .logo{font-size:1.15rem}
      .cart-btn{padding:.38rem .72rem;font-size:.8rem}
      .cart-dropdown{width:calc(100vw - 1rem);right:-0.5rem}
      .hero-inner{padding:3rem .9rem 1.8rem}
      .category-bar,.menu-section,.checkout-wrap{padding-left:.9rem;padding-right:.9rem}
      .menu-grid{grid-template-columns:1fr}
      .form-row,.grid2{grid-template-columns:1fr}
      .hero p{font-size:1rem}
      .map-container{height:260px}
    }
  </style>
</head>
<body>

<nav>
  <div class="nav-row1">
    <div class="logo">Napo<span>li</span></div>
    <div class="nav-spacer"></div>
    <div class="nav-center">
      <button class="nav-tab active" onclick="showPage('menu')">Меню</button>
      <button class="nav-tab" onclick="showPage('checkout')">Оформление</button>
    </div>
    <div class="nav-spacer"></div>
    <div class="cart-wrap">
      <button class="cart-btn" onclick="toggleCart()">Корзина <span class="cart-count" id="cartCount">0</span></button>
      <div class="cart-dropdown" id="cartDropdown">
        <div class="cart-header">
          <h2>Ваш заказ</h2>
          <button class="close-btn" onclick="toggleCart()">✕</button>
        </div>
        <div class="cart-items" id="cartItems"></div>
        <div class="cart-footer" id="cartFooter" style="display:none;">
          <div class="cart-total"><span>Итого:</span><span id="cartTotal">0</span></div>
          <button class="checkout-btn" onclick="goCheckout()">Оформить заказ →</button>
        </div>
      </div>
    </div>
  </div>
  <div class="nav-row2">
    <div class="currency-switcher">
      <button class="cur-btn active" onclick="setCurrency('rub')">RUB</button>
      <button class="cur-btn" onclick="setCurrency('usd')">USD</button>
      <button class="cur-btn" onclick="setCurrency('egp')">EGP</button>
    </div>
    <div class="nav-divider"></div>
    <div class="nav-phone">📞 5555555</div>
  </div>
  <div class="nav-row3"></div>
</nav>

<div class="cart-backdrop" id="cartBackdrop" onclick="toggleCart()"></div>

<div class="page active" id="page-menu">
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-badge">Пицца, паста и доставка по Шарм-эль-Шейху</div>
      <h1>Настоящая итальянская пицца, приготовленная с душой</h1>
      <p>Свежие ингредиенты, ароматная выпечка и быстрая доставка. Выберите любимые блюда, добавьте их в корзину и оформите заказ за пару минут.</p>
      <div class="hero-actions">
        <a href="#menu-section" class="hero-btn primary" onclick="showPage('menu')">Смотреть меню</a>
        <a href="#checkout" class="hero-btn secondary" onclick="goCheckout()">Оформить заказ</a>
      </div>
    </div>
  </section>

  <div class="category-bar" id="catBar"></div>

  <section class="menu-section" id="menu-section">
    <h2 class="section-title">Меню</h2>
    <p class="section-sub">Выберите пиццу, пасту, десерт или напиток. Для пиццы доступны разные размеры, а цена автоматически пересчитывается.</p>
    <div class="menu-grid" id="menuGrid"></div>
  </section>
</div>

<div class="page" id="page-checkout">
  <div class="checkout-wrap" id="checkout">
    <h2 class="form-title" id="pageTitle">Оформление заказа</h2>

    <div class="summary-box">
      <div class="summary-title" id="lblYourOrder">Ваш заказ</div>
      <div id="summaryItems"></div>
      <div class="os-line total" id="summaryTotalRow" style="display:none;">
        <span id="lblTotal">Итого:</span>
        <span id="summaryTotal">0</span>
      </div>
    </div>

    <div class="delivery-type">
      <div class="del-opt selected" id="optDelivery" onclick="selectDelivery('delivery', this)">🛵 Доставка</div>
      <div class="del-opt" id="optPickup" onclick="selectDelivery('pickup', this)">🏃 Самовывоз</div>
    </div>

    <div class="form-group">
      <label id="lblName">Имя *</label>
      <input type="text" id="fName" placeholder="Иван">
    </div>

    <div class="form-group">
      <label id="lblPhone">Телефон *</label>
      <input type="tel" id="fPhone" placeholder="+7 999 123-45-67">
    </div>

    <div class="form-group" id="addressGroup">
      <label id="lblAddress">Адрес доставки *</label>

      <div class="map-section">
        <div class="map-label"><span id="lblMap">🗺️ Карта Шарм-эль-Шейха</span></div>
        <div class="map-container" id="mapContainer">
          <iframe
            src="https://www.openstreetmap.org/export/embed.html?bbox=34.342%2C27.822%2C34.482%2C28.05&layer=mapnik&marker=27.9152%2C34.33"
            allowfullscreen
            loading="lazy"></iframe>
        </div>
        <div class="map-hint" id="hintMap">Карта показывает зону доставки Шарм-эль-Шейха</div>
      </div>

      <div class="zones" id="zonesWrap">
        <button type="button" class="zone-btn" onclick="selectZone('Naama Bay')">Naama Bay</button>
        <button type="button" class="zone-btn" onclick="selectZone('Hadaba')">Hadaba</button>
        <button type="button" class="zone-btn" onclick="selectZone('Sharks Bay')">Sharks Bay</button>
        <button type="button" class="zone-btn" onclick="selectZone('Nabq')">Nabq</button>
        <button type="button" class="zone-btn" onclick="selectZone('Ras Nasrani')">Ras Nasrani</button>
        <button type="button" class="zone-btn" onclick="selectZone('Old Market')">Old Market</button>
        <button type="button" class="zone-btn" onclick="selectZone('Montazah')">Montazah</button>
        <button type="button" class="zone-btn" onclick="selectZone('Sharm El Maya')">Sharm El Maya</button>
      </div>

      <div class="info-box green" id="zoneBox"></div>

      <div class="divider" id="lblDetails">+ детали адреса</div>

      <div class="grid2">
        <div class="field">
          <label id="lblDistrict">Район *</label>
          <input type="text" id="fDistrict" placeholder="Naama Bay">
        </div>
        <div class="field">
          <label id="lblHotel">Отель</label>
          <input type="text" id="fHotel" placeholder="Sunrise, Rixos">
        </div>
        <div class="field">
          <label id="lblStreet">Улица</label>
          <input type="text" id="fStreet">
        </div>
        <div class="field">
          <label id="lblBuilding">Здание</label>
          <input type="text" id="fBuilding">
        </div>
        <div class="field">
          <label id="lblRoom">№ комнаты</label>
          <input type="text" id="fRoom" placeholder="205">
        </div>
        <div class="field">
          <label id="lblLandmark">Ориентир</label>
          <input type="text" id="fLandmark">
        </div>
      </div>
    </div>

    <div class="form-group">
      <label id="lblComment">Комментарий</label>
      <textarea id="fComment" rows="2" placeholder="Без лука, позвонить за 5 минут до приезда..."></textarea>
    </div>

    <button class="submit-btn" id="submitBtn" onclick="placeOrder()">✅ Подтвердить заказ</button>
  </div>
</div>

<div class="page" id="page-success">
  <div class="checkout-wrap">
    <div class="success-wrap show" id="successWrap">
      <span class="success-emoji">🍕</span>
      <h2 id="successTitle">Заказ принят!</h2>
      <p id="successSub">Мы уже начали готовить вашу пиццу. Ожидайте доставку через 30–45 минут.</p>
      <div class="order-number" id="orderNum">Заказ №1234</div>
      <div class="success-sms" id="successSms">📱 Ожидайте подтверждение в виде СМС.</div>
      <button class="menu-btn" onclick="showPage('menu')">← Вернуться в меню</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
  const CURRENCIES = {
    rub: { symbol: "₽", rate: 1, decimals: 0, before: false },
    usd: { symbol: "$", rate: 0.011, decimals: 2, before: true },
    egp: { symbol: "ج.م", rate: 0.55, decimals: 2, before: false }
  };

  let currency = 'rub';
  let cart = [];
  let deliveryType = 'delivery';
  let selectedSizes = {};
  let currentCat = 'all';
  let chosenZone = '';

  const MENUDATA = [
    { id: 1, cat: 'pizza', name: 'Маргарита', desc: 'Томатный соус, моцарелла, базилик', emoji: '🍕', badge: 'ХИТ', hasSizes: true, price: 490 },
    { id: 2, cat: 'pizza', name: 'Пепперони', desc: 'Пикантная колбаска, томаты, моцарелла', emoji: '🍕', badge: '', hasSizes: true, price: 590 },
    { id: 3, cat: 'pizza', name: 'Четыре сыра', desc: 'Моцарелла, пармезан, горгонзола, рикотта', emoji: '🧀', badge: 'NEW', hasSizes: true, price: 650 },
    { id: 4, cat: 'pizza', name: 'Карбонара', desc: 'Бекон, яйцо, пармезан, сливочный соус', emoji: '🍕', badge: '', hasSizes: true, price: 620 },
    { id: 5, cat: 'pizza', name: 'Гавайская', desc: 'Ветчина, ананас, моцарелла', emoji: '🍍', badge: '', hasSizes: true, price: 550 },
    { id: 6, cat: 'pizza', name: 'Грибная', desc: 'Шампиньоны, трюфельное масло, моцарелла', emoji: '🍄', badge: '', hasSizes: true, price: 520 },
    { id: 7, cat: 'pasta', name: 'Болоньезе', desc: 'Мясной соус, томаты, пармезан', emoji: '🍝', badge: '', hasSizes: false, price: 420 },
    { id: 8, cat: 'pasta', name: 'Альфредо', desc: 'Сливочный соус, курица, пармезан', emoji: '🍝', badge: 'ХИТ', hasSizes: false, price: 440 },
    { id: 9, cat: 'salad', name: 'Цезарь', desc: 'Курица, романо, пармезан', emoji: '🥗', badge: '', hasSizes: false, price: 380 },
    { id: 10, cat: 'salad', name: 'Греческий', desc: 'Фета, огурцы, томаты, оливки', emoji: '🥗', badge: '', hasSizes: false, price: 320 },
    { id: 11, cat: 'dessert', name: 'Тирамису', desc: 'Маскарпоне, эспрессо, савоярди', emoji: '🍰', badge: 'ХИТ', hasSizes: false, price: 280 },
    { id: 12, cat: 'dessert', name: 'Панна Котта', desc: 'Сливки, ваниль, ягодный соус', emoji: '🍮', badge: '', hasSizes: false, price: 240 },
    { id: 13, cat: 'drink', name: 'Лимонад', desc: 'Лимон, мята, имбирь', emoji: '🥤', badge: '', hasSizes: false, price: 180 },
    { id: 14, cat: 'drink', name: 'San Pellegrino', desc: 'Газированная вода, 500 мл', emoji: '💧', badge: '', hasSizes: false, price: 150 },
    { id: 15, cat: 'drink', name: 'Чай', desc: 'Яблоко, корица, гвоздика', emoji: '🍵', badge: '', hasSizes: false, price: 160 }
  ];

  function formatPrice(rubPrice){
    const cur = CURRENCIES[currency];
    const val = rubPrice * cur.rate;
    const fmt = val.toFixed(cur.decimals).replace(/B(?=(d{3})+(?!d))/g, ' ');
    return cur.before ? `${cur.symbol} ${fmt}` : `${fmt} ${cur.symbol}`;
  }

  function setCurrency(c){
    currency = c;
    document.querySelectorAll('.cur-btn').forEach(b => b.classList.toggle('active', b.textContent.toLowerCase() === c));
    renderMenu();
    updateCartUI();
    renderSummary();
  }

  function showPage(name){
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.getElementById(`page-${name}`).classList.add('active');
    document.querySelectorAll('.nav-tab').forEach(btn => btn.classList.remove('active'));
    const tabs = [...document.querySelectorAll('.nav-tab')];
    if(name === 'menu' && tabs[0]) tabs[0].classList.add('active');
    if(name === 'checkout' && tabs[1]) tabs[1].classList.add('active');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function getSizes(item){
    if(!item.hasSizes) return null;
    return { S: item.price, M: item.price + 200, L: item.price + 400 };
  }

  function renderCatBar(){
    const cats = ['all','pizza','pasta','salad','drink','dessert'];
    const labels = {
      all:'Все блюда',
      pizza:'Пицца',
      pasta:'Паста',
      salad:'Салаты',
      drink:'Напитки',
      dessert:'Десерты'
    };
    document.getElementById('catBar').innerHTML = cats.map(c =>
      `<button class="cat-btn ${currentCat===c?'active':''}" onclick="filterCat('${c}', this)">${labels[c]}</button>`
    ).join('');
  }

  function filterCat(cat, el){
    currentCat = cat;
    document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
    el.classList.add('active');
    renderMenu();
    document.getElementById('menu-section').scrollIntoView({behavior:'smooth', block:'start'});
  }

  function renderMenu(cat = currentCat){
    currentCat = cat;
    const grid = document.getElementById('menuGrid');
    const items = cat === 'all' ? MENUDATA : MENUDATA.filter(i => i.cat === cat);
    grid.innerHTML = items.map(item => {
      const sizes = getSizes(item);
      const sKey = `sel${item.id}`;
      if(sizes && !selectedSizes[sKey]) selectedSizes[sKey] = 'M';
      const selectedSize = sizes ? selectedSizes[sKey] : null;
      const price = sizes ? sizes[selectedSize] : item.price;
      const badge = item.badge ? `<div class="card-badge">${item.badge}</div>` : '';
      const sizesHTML = sizes ? `
        <div class="size-sel">
          ${Object.entries(sizes).map(([s,p]) => `<div class="size-opt ${selectedSize===s?'selected':''}" onclick="selectSize(${item.id}, '${s}', this)">${s} ${formatPrice(p)}</div>`).join('')}
        </div>` : '';
      return `
        <div class="card" id="card-${item.id}">
          <div class="card-img">${item.emoji}${badge}</div>
          <div class="card-body">
            <div class="card-name">${item.name}</div>
            <div class="card-desc">${item.desc}</div>
            ${sizesHTML}
            <div class="card-footer">
              <div class="card-price" id="price-${item.id}">${sizes ? 'от ' : ''}${formatPrice(price)}</div>
              <button class="add-btn" onclick="addToCart(${item.id})" title="Добавить">+</button>
            </div>
          </div>
        </div>
      `;
    }).join('');
  }

  function selectSize(id, size, el){
    selectedSizes[`sel${id}`] = size;
    el.parentElement.querySelectorAll('.size-opt').forEach(s => s.classList.remove('selected'));
    el.classList.add('selected');
    const item = MENUDATA.find(i => i.id === id);
    const sizes = getSizes(item);
    document.getElementById(`price-${id}`).textContent = `от ${formatPrice(sizes[size])}`;
  }

  function addToCart(id){
    const item = MENUDATA.find(i => i.id === id);
    const sizes = getSizes(item);
    const size = sizes ? selectedSizes[`sel${id}`] : null;
    const price = sizes ? sizes[size] : item.price;
    const key = `${id}-${size || 'default'}`;
    const existing = cart.find(c => c.key === key);
    if(existing) existing.qty += 1;
    else cart.push({ key, id, name: item.name, emoji: item.emoji, size, price, qty: 1 });
    updateCartUI();
    showToast(`${item.emoji} ${item.name} добавлен в корзину`);
  }

  function updateCartUI(){
    const total = cart.reduce((s,c) => s + c.price * c.qty, 0);
    const count = cart.reduce((s,c) => s + c.qty, 0);
    document.getElementById('cartCount').textContent = count;

    const itemsEl = document.getElementById('cartItems');
    const footerEl = document.getElementById('cartFooter');

    if(!cart.length){
      itemsEl.innerHTML = `<div class="empty-cart"><span class="emoji">🛒</span>Корзина пуста</div>`;
      footerEl.style.display = 'none';
      return;
    }

    footerEl.style.display = 'block';
    document.getElementById('cartTotal').textContent = formatPrice(total);

    itemsEl.innerHTML = cart.map((c,i) => `
      <div class="cart-item">
        <div class="ci-emoji">${c.emoji}</div>
        <div class="ci-info">
          <div class="ci-name">${c.name}${c.size ? `, ${c.size}` : ''}</div>
          <div class="qty-ctrl">
            <button class="qty-btn" onclick="changeQty(${i}, -1)">−</button>
            <span class="qty-val">${c.qty}</span>
            <button class="qty-btn" onclick="changeQty(${i}, 1)">+</button>
          </div>
        </div>
        <div class="ci-price">${formatPrice(c.price * c.qty)}</div>
      </div>
    `).join('');
  }

  function changeQty(i, delta){
    cart[i].qty += delta;
    if(cart[i].qty <= 0) cart.splice(i,1);
    updateCartUI();
  }

  function toggleCart(){
    document.getElementById('cartDropdown').classList.toggle('open');
    document.getElementById('cartBackdrop').classList.toggle('open');
  }

  function renderSummary(){
    const el = document.getElementById('summaryItems');
    const totalRow = document.getElementById('summaryTotalRow');
    if(!cart.length){
      el.innerHTML = `<div class="empty-msg">Корзина пуста</div>`;
      totalRow.style.display = 'none';
      return;
    }
    const total = cart.reduce((s,c) => s + c.price * c.qty, 0);
    el.innerHTML = cart.map(c => `
      <div class="os-line">
        <span>${c.emoji} ${c.name}${c.size ? `, ${c.size}` : ''} × ${c.qty}</span>
        <span>${formatPrice(c.price * c.qty)}</span>
      </div>
    `).join('');
    document.getElementById('summaryTotal').textContent = formatPrice(total);
    totalRow.style.display = 'flex';
  }

  function goCheckout(){
    if(!cart.length){
      showToast('Корзина пуста');
      return;
    }
    renderSummary();
    showPage('checkout');
    toggleCart();
  }

  function selectDelivery(type, el){
    deliveryType = type;
    document.querySelectorAll('.del-opt').forEach(d => d.classList.remove('selected'));
    el.classList.add('selected');
    document.getElementById('addressGroup').style.display = type === 'delivery' ? 'block' : 'none';
  }

  function selectZone(zone){
    chosenZone = zone;
    document.getElementById('fDistrict').value = zone;
    document.querySelectorAll('.zone-btn').forEach(b => b.classList.toggle('active', b.textContent.trim() === zone));
    const box = document.getElementById('zoneBox');
    box.textContent = `Выбран район: ${zone}`;
    box.classList.add('show');
  }

  function placeOrder(){
    const name = document.getElementById('fName').value.trim();
    const phone = document.getElementById('fPhone').value.trim();
    const district = document.getElementById('fDistrict').value.trim();

    if(!name || !phone){
      showToast('Пожалуйста, заполните имя и телефон');
      return;
    }
    if(deliveryType === 'delivery' && !district){
      showToast('Пожалуйста, выберите район доставки');
      return;
    }

    const num = Math.floor(Math.random() * 9000 + 1000);
    document.getElementById('orderNum').textContent = `Заказ №${num}`;
    cart = [];
    updateCartUI();
    renderSummary();
    showPage('success');
  }

  function showToast(msg){
    const el = document.getElementById('toast');
    el.textContent = msg;
    el.classList.add('show');
    setTimeout(() => el.classList.remove('show'), 2500);
  }

  document.querySelectorAll('.cur-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.cur-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  renderCatBar();
  renderMenu();
  updateCartUI();
</script>
</body>
</html>
